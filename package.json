{
  "name": "rihla-mate",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "license-server"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "check": "turbo check",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "keygen": "tsx scripts/keygen.ts",
    "prepare": "husky",
    "test": "pnpm -C apps/app test"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@better-auth/utils": "0.4.2",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "tsx": "^4.22.4",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.0.0+sha512.b4106707c7225b1748b61595953ccbebff97b54ad05d002aa3635f633b9c53cd666f7ce9b8bc44704f1fa048b9a49b55371ab2d9e9d667d1efe2ef1514bcd513",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write",
      "eslint --fix --max-warnings 0",
      "apps/app/node_modules/.bin/vitest related --run --config apps/app/vitest.config.mts",
      "bash -c 'tsc --noEmit -p apps/app/tsconfig.json'"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "patchedDependencies": {
      "@opennextjs/cloudflare@1.20.1": "patches/@opennextjs__cloudflare@1.20.1.patch",
      "@opennextjs/aws@4.0.2": "patches/@opennextjs__aws@4.0.2.patch"
    }
  }
}

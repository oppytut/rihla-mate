# =============================================================================
# Rihla Mate — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with ⚠️. All others are optional and have
# sensible defaults for development.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# ⚠️ PostgreSQL connection string.
# Format: postgres://<user>:<password>@<host>:<port>/<database>
# Default (dev): postgres://rihlamate:rihlamate@localhost:5432/rihlamate_dev
DATABASE_URL=postgres://rihlamate:rihlamate_dev@localhost:5432/rihlamate_dev

# ---------------------------------------------------------------------------
# Auth (Better Auth)
# ---------------------------------------------------------------------------

# ⚠️ Secret used to encrypt session cookies and JWTs.
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=change-me-to-a-random-secret

# Base URL for the auth service (callback URLs, redirects).
# For development: http://localhost:3000
# For production: https://your-domain.com
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth 2.0 credentials (optional — needed for Google sign-in).
# Obtain from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---------------------------------------------------------------------------
# License
# ---------------------------------------------------------------------------

# License key issued by the Rihla Mate license server.
# Leave empty to start in trial mode (14 days).
LICENSE_KEY=

# Ed25519 public key (base64-encoded) for offline license signature verification.
# Generate with: pnpm keygen
LICENSE_PUBLIC_KEY=your-ed25519-public-key

# URL of the central license server for phone-home check-ins.
# Default (dev): http://localhost:3001
LICENSE_SERVER_URL=http://localhost:3001

# ---------------------------------------------------------------------------
# Email (Resend)
# ---------------------------------------------------------------------------

# ⚠️ Resend API key for sending transactional emails.
# Obtain from: https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key

# Sender email address for outgoing emails.
# Defaults to the first verified domain in your Resend account.
RESEND_FROM_EMAIL=noreply@your-domain.com

# ---------------------------------------------------------------------------
# Payments (Midtrans)
# ---------------------------------------------------------------------------

# Midtrans server key (starts with "Mid-server-" for production,
# "SB-Mid-server-" for sandbox).
# Obtain from: https://dashboard.midtrans.com
MIDTRANS_SERVER_KEY=SB-Mid-server-your-sandbox-server-key

# Midtrans client key (public, safe to expose to the browser).
MIDTRANS_CLIENT_KEY=SB-Mid-client-your-sandbox-client-key

# Public-facing Midtrans client key (used in Next.js client components).
# Same value as MIDTRANS_CLIENT_KEY above.
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-your-sandbox-client-key

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------

# Storage driver: "local" (default) or "s3"
STORAGE_DRIVER=local

# --- S3 / S3-compatible storage (only needed when STORAGE_DRIVER=s3) ---

S3_ENDPOINT=https://your-s3-endpoint.com
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_BUCKET=your-s3-bucket-name
S3_REGION=us-east-1

# ---------------------------------------------------------------------------
# App (Public)
# ---------------------------------------------------------------------------

# Public-facing URL of the application.
# For development: http://localhost:3000
# For production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

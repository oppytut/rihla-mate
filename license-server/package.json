{
  "name": "@rihla-mate/license-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:bootstrap": "tsx scripts/bootstrap.ts",
    "keygen": "tsx scripts/keygen-cli.ts",
    "deploy:cf": "wrangler deploy",
    "deploy:cf:prod": "wrangler deploy --env production"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@neondatabase/serverless": "^0.9.5",
    "@noble/ed25519": "^2.1.0",
    "@rihla-mate/shared": "workspace:^",
    "@upstash/redis": "^1.34.8",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.12.26",
    "resend": "^4.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.17.0",
    "drizzle-kit": "^0.31.7",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.110.0"
  }
}

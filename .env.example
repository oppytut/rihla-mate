# =============================================
# Rihla Mate — Environment Configuration
# =============================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# =============================================

# --- Database ---
DATABASE_URL=postgres://rihlamate:rihlamate_dev@localhost:5432/rihlamate_dev
DB_USER=rihlamate
DB_PASSWORD=change_me_to_a_secure_password
DB_NAME=rihlamate

# --- Application ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_PORT=3000

# --- Authentication (Better Auth) ---
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=change_me_to_a_random_64_char_string
BETTER_AUTH_URL=http://localhost:3000

# --- Google OAuth (optional) ---
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- License ---
# Leave empty to start in 14-day trial mode
LICENSE_KEY=
# Public key for offline license verification (base64 encoded Ed25519 public key)
LICENSE_PUBLIC_KEY=

# --- Email (Resend) ---
# https://resend.com/api-keys
RESEND_API_KEY=
# Email sender address (must be verified in Resend)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# --- Payments (Midtrans) ---
# https://dashboard.midtrans.com → Settings → Access Keys
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=

# --- Storage ---
# Options: local | s3
STORAGE_DRIVER=local

# S3-compatible storage (optional)
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=rihla-mate-uploads
# S3_REGION=us-east-1

# --- Development ---
NODE_ENV=development
